# MySQL (docker-compose / local)
MYSQL_ROOT_PASSWORD=sdc_dev_root
MYSQL_DATABASE=sdc
MYSQL_USER=sdc
MYSQL_PASSWORD=sdc_dev
MYSQL_PORT=33306

# Backend — copy to packages/backend/.env
# DATABASE_URL="mysql://sdc:sdc_dev@localhost:3306/sdc"
# SESSION_SECRET=change-me-in-production
# デモ用サンプル API: SDC_SAMPLE_DATA=1（本番では無効）
# 開発のみログインスキップ（実データ）: SDC_RELAX_AUTH=1
#
# Frontend — copy to packages/frontend/.env.local
# ログインスキップとバナー: NEXT_PUBLIC_SDC_SAMPLE_DATA=1（バックエンドの SDC_SAMPLE_DATA と併用）

