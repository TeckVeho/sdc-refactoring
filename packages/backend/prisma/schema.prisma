  sehncd   String  @map("sehncd")
  syouso   String? @map("syouso")
  kainame  String? @map("kainame")
  nouki    String? @map("nouki")
  pass     String? @map("pass")
  nyukabi  String? @map("nyukabi")
  nyukasu  Int?    @map("nyukasu")
  incnt    Int?    @map("incnt")

  @@map("zaiko")
}

model Zaikor {
  uno      String  @id @map("uno")
  kaisyacd String  @map("kaisyacd")
  sehncd   String  @map("sehncd")
  syouso   String? @map("syouso")
  kainame  String? @map("kainame")
  nouki    String? @map("nouki")
  pass     String? @map("pass")
  nyukabi  String? @map("nyukabi")
  nyukasu  Int?    @map("nyukasu")
  incnt    Int?    @map("incnt")

  @@map("zaikor")
}

model Syukar {
  id       BigInt @id @default(autoincrement())
  kaisyacd String @map("kaisyacd")
  syudate  String @map("syudate")
  syukasu  Int?   @map("syukasu")

  @@index([kaisyacd, syudate])
  @@map("syukar")
}

