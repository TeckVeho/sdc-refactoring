// SDC — Oracle/Access 由来テーブルは @@map で物理名を維持
// カラムは仕様書で確定したものを優先。未確定は後続マイグレーションで拡張可能な最小形。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  manager
  operator
  viewer
}

// --- Web 新規 ---

model User {
  id           String   @id @default(cuid())
  employeeId   String   @unique @map("employee_id")
  role         UserRole @default(viewer)
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  shain Shainmst @relation(fields: [employeeId], references: [shano])

  @@map("users")
}

model WebSession {
  sessionId String @id @map("session_id") @db.VarChar(128)
  expires   Int    @map("expires")
  data      String @map("data") @db.MediumText

  @@map("web_sessions")
}

model CorrectionCoefficient {
  id            String   @id @default(cuid())
  name          String
  value         Decimal  @db.Decimal(24, 12)
  effectiveFrom DateTime @map("effective_from") @db.Date

  @@map("correction_coefficients")
}

// --- マスタ ---

model Tokumst {
  kaisyacd String  @id @map("kaisyacd")
  coname   String
  kairname String? @map("kairname")

  @@map("tokumst")
}

model Sehmst {
  kaisyacd String  @map("kaisyacd")
  sehncd   String  @map("sehncd")
  seiname  String
  syouho   String?

  @@id([kaisyacd, sehncd])
  @@map("sehmst")
}

model Shainmst {
  shano   String  @id @map("shano")
  shaname String  @map("shaname")
  shask   String? @map("shask")
  hshika  String? @map("hshika")
  cshika  String? @map("cshika")

  users User[]

  @@map("shainmst")
}

model Senkind {
  kindcd String  @id @map("kindcd")
  name   String?

  @@map("senkind")
}

model Keicode {
  keicode String  @id @map("keicode")
  keisiki String? @map("keisiki")

  @@map("keicode")
}

model Kcdcnvmst {
  gammacd String @map("gammacd")
  ebcd    String @map("ebcd")
  memo    String?

  @@id([gammacd, ebcd])
  @@map("kcdcnvmst")
}

model Tsyjmst {
  chumoncd String  @id @map("chumoncd")
  kaisyacd String? @map("kaisyacd")
  biko     String?

  @@map("tsyjmst")
}

// --- 在庫・出荷 ---

model Zaiko {
  uno      String  @id @map("uno")
