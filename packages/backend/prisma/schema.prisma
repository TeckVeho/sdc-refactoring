// --- 勤務（旧 Access）---

model ShiftSchedule {
  id         String   @id @default(cuid()) @map("id")
  cycleStart DateTime @map("cycle_start") @db.Date
  label      String?  @map("label")
  raw        Json?    @map("raw")

  @@map("shift_schedules")
}

model ShiftEmployee {
  id    String  @id @default(cuid()) @map("id")
  shano String  @map("shano")
